# Chronex client environment variables
# Copy this file to `.env.local` for local development.




# Postgres connection string used by Drizzle.
DATABASE_URL=POSTGRES_CONNECTION_STRING


# Better Auth configuration.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL=http://localhost:3000


# Public base URL used for callbacks and generated links.
NEXT_PUBLIC_APP_URL=http://localhost:3000




# -----------------------------------------------------------------------------
# Auth providers
# -----------------------------------------------------------------------------


# GitHub OAuth
GITHUB_CLIENT_ID=GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=GITHUB_CLIENT_SECRET

# Google OAuth
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET


# Instagram OAuth
NEXT_PUBLIC_INSTA_APP_ID=INSTAGRAM_APP_ID
INSTA_APP_SECRET=INSTAGRAM_APP_SECRET
NEXT_PUBLIC_INSTA_REDIRECT_URI="http://localhost:3000/instagram"


# Threads OAuth
NEXT_PUBLIC_THREADS_APP_ID=THREADS_APP_ID
THREADS_CLIENT_SECRET=THREADS_CLIENT_SECRET
NEXT_PUBLIC_THREADS_REDIRECT_URI="http://localhost:3000/threads"


# LinkedIn OAuth
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=LINKEDIN_CLIENT_SECRET
NEXT_PUBLIC_LINKEDIN_REDIRECT_URI="http://localhost:3000/linkedin"


# Slack OAuth
NEXT_PUBLIC_SLACK_CLIENT_ID=SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=SLACK_CLIENT_SECRET
NEXT_PUBLIC_SLACK_REDIRECT_URI="http://localhost:3000/slack"


# Discord OAuth
NEXT_PUBLIC_DISCORD_CLIENT_ID=DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=DISCORD_CLIENT_SECRET
NEXT_PUBLIC_DISCORD_REDIRECT_URI="http://localhost:3000/discord"
DISCORD_BOT_TOKEN=DISCORD_BOT_TOKEN      # Required for bot-authenticated Discord API requests.


# Telegram OAuth
TELEGRAM_BOT_TOKEN=TELEGRAM_BOT_TOKEN
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=NEXT_PUBLIC_TELEGRAM_BOT_USERNAME
TELEGRAM_WEBHOOK_SECRET="replace-with-a-long-random-secret"



# -----------------------------------------------------------------------------
# File storage
# -----------------------------------------------------------------------------


# Backblaze B2
B2_KEY_ID=BACKBLAZE_KEY_ID
B2_APP_KEY=BACKBLAZE_APP_KEY
B2_BUCKET_ID=BACKBLAZE_BUCKET_ID
B2_DOWNLOAD_URL=BACKBLAZE_DOWNLOAD_URL



# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------

CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_QUEUE_ID=YOUR_CLOUDFLARE_QUEUE_ID



# -----------------------------------------------------------------------------
# Public links shown in the UI
# -----------------------------------------------------------------------------

NEXT_PUBLIC_GITHUB_URL="https://github.com/your-org/chronex"
NEXT_PUBLIC_X_URL="https://x.com/prncexe"
NEXT_PUBLIC_GITHUB_SPONSORS_URL="https://github.com/sponsors/prncexe"
NEXT_PUBLIC_KOFI_URL="https://ko-fi.com/prncexe"
NEXT_PUBLIC_PAYPAL_URL="https://paypal.me/prncexe"



# -----------------------------------------------------------------------------
# OPTIONAL CONFIGURATION
# These variables are optional and only needed for specific features.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_MAX_WORKSPACE=9999
NEXT_PUBLIC_MAX_POSTS_PER_WORKSPACE=9999
NEXT_PUBLIC_MAX_MEDIA_PER_WORKSPACE=9999
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=9999
NEXT_PUBLIC_PLATFORM_BLACKLIST=""
